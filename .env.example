# Mandatory
ENCRYPTION_KEY=replace-with-a-fernet-key-generated-by-python-fernet-generate-key
# Secret key for JWT API authentication
JWT_SECRET_KEY=replace-with-at-least-32-random-bytes-for-hs256

# [Optional] Compose already has this default values.
# DB_HOST=pgwarden_db
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=postgres

# [Optional] API Port config.
# API_PORT=8080

# [Optional] Comma-separated browser origins allowed to call the API.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Embeddings are generated using the bgem3 model with 1024 dimensions.
# The provider endpoint is configured in config.yaml / api/utils/embeddings.py.
