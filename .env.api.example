# API service environment variables.
# Copy this file to .env.api and customize it if you want to run the API
# container with its own dedicated environment file.

# Mandatory secrets
ENCRYPTION_KEY=replace-with-a-fernet-key-generated-by-python-fernet-generate-key
JWT_SECRET_KEY=replace-with-at-least-32-random-bytes-for-hs256

# Database connection
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# Default admin user created on first run
PGWARDEN_EMAIL=admin@pgwarden.com
PGWARDEN_PASSWORD=admin

# Optional: use OpenRouter for embeddings instead of downloading BGE-M3 locally
# OPENROUTER_API_KEY=sk-or-...
